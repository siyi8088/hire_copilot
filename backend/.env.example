# Boss直聘猎头 Copilot 环境配置
# 复制此文件为 .env 并填入你的配置

# ---- LLM 配置 ----
# 支持的 Provider: deepseek / mimo / openai / ollama
#
# === DeepSeek 配置 ===
# LLM_PROVIDER=deepseek
# LLM_API_KEY=你的DeepSeek API Key
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
#
# === 小米 MiMo 配置 (推荐) ===
# API Key 在 https://platform.xiaomimimo.com/#/console/api-keys 创建
LLM_PROVIDER=mimo
LLM_API_KEY=你的MiMo API Key
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
# 可选模型: mimo-v2.5-pro(旗舰), mimo-v2.5(多模态), mimo-v2-flash(最便宜)

# ---- 微信通知（可选）----
# 企业微信群机器人 Webhook URL
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ---- 安全策略 ----
MAX_REPLIES_PER_HOUR=20
MAX_GREETINGS_PER_HOUR=8
WORK_HOUR_START=9
WORK_HOUR_END=21
MAX_DAILY_MESSAGES=150
